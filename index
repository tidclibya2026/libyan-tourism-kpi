  .chart-container-decision { background: linear-gradient(135deg, #0a2b3e, #1a3f62); padding: 1rem; border-radius: 1rem; margin-top: 1rem; }
  .dashboard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem; }
  .dashboard-card { background: var(--card-bg); border-radius: 1.5rem; padding: 1rem; border: 1px solid var(--border-light); transition: all 0.2s; }
