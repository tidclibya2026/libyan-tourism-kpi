<script>
// ------------------------- البيانات الأساسية -------------------------
const UNWTO_DATA = {
  tourists: 2752, avgStay: 5, dailyUSD: 120, exchange: 8.5,
  domesticRevenue: 1250797500, beds: 75606, population: 7000000, gdp: 200000000000
};
function computeMetrics() {
  const dailyLYD = UNWTO_DATA.dailyUSD * UNWTO_DATA.exchange;
  const spendPerTourist = dailyLYD * UNWTO_DATA.avgStay;
  const nights = UNWTO_DATA.tourists * UNWTO_DATA.avgStay;
  const intlRevenue = UNWTO_DATA.tourists * spendPerTourist;
  const totalRevenue = UNWTO_DATA.domesticRevenue + intlRevenue;
  const occupancy = (nights / (UNWTO_DATA.beds * 365)) * 100;
  const density = (UNWTO_DATA.tourists / UNWTO_DATA.population) * 1000;
  const bedProductivity = UNWTO_DATA.tourists / UNWTO_DATA.beds;
  const gdpShare = (totalRevenue / UNWTO_DATA.gdp) * 100;
  return { totalRevenue, intlRevenue, nights, occupancy, density, bedProductivity, gdpShare, spendPerTourist, dailyLYD };
}

// ------------------------- بطاقات القرار -------------------------
function renderDecisionCards() {
  const metrics = computeMetrics();
  const totalRevB = (metrics.totalRevenue / 1e9).toFixed(3);
  const intlSpendM = (metrics.intlRevenue / 1e6).toFixed(2);
  const indicators = [
    { id:"totalRev", title:"إجمالي الإيرادات السياحية", value:totalRevB + " مليار د.ل", icon:"fas fa-dollar-sign",
      def:"إجمالي العوائد الناتجة عن النشاط السياحي (مباشر وغير مباشر).",
      formula:"الإيرادات = عدد السياح × متوسط الإنفاق × مدة الإقامة + الإيرادات المحلية",
      analysis:"الرقم يعكس نشاطاً اقتصادياً قائماً لكنه يعتمد غالباً على السياحة الداخلية أو الحكومية." },
    { id:"avgStay", title:"متوسط مدة الإقامة", value:UNWTO_DATA.avgStay + " أيام", icon:"fas fa-calendar-week",
      def:"عدد الأيام التي يقضيها السائح داخل الدولة.",
      formula:"إجمالي الليالي السياحية / عدد السياح",
      analysis:"مؤشر إيجابي نسبياً؛ يدل على وجود خدمات كافية للإقامة." },
    { id:"occupancy", title:"معدل الإشغال السنوي", value:metrics.occupancy.toFixed(2)+"%", icon:"fas fa-bed",
      def:"نسبة إشغال الفنادق من إجمالي الطاقة الاستيعابية.",
      formula:"(الليالي السياحية / (الأسرة × 365)) × 100",
      analysis:"هذا الرقم حرج جداً (أقل من 1%)، يدل على ضعف الطلب السياحي." },
    { id:"gdpShare", title:"مساهمة السياحة في الناتج المحلي", value:metrics.gdpShare.toFixed(2)+"%", icon:"fas fa-chart-line",
      def:"نسبة مساهمة القطاع السياحي في الناتج المحلي الإجمالي.",
      formula:"(إجمالي الإيرادات السياحية / الناتج المحلي) × 100",
      analysis:"نسبة ضعيفة جداً (أقل من 1%)، بينما تتراوح النسبة في الدول السياحية بين 10-25%." },
    { id:"intlSpend", title:"إنفاق السائح الدولي", value:intlSpendM + " مليون د.ل", icon:"fas fa-money-bill-wave",
      def:"إجمالي ما ينفقه السياح الدوليون خلال زياراتهم.",
      formula:"عدد السياح × متوسط الإنفاق اليومي × مدة الإقامة",
      analysis:"منخفض جداً بسبب قلة عدد السياح الدوليين." },
    { id:"tourists", title:"عدد السياح الدوليين", value:UNWTO_DATA.tourists.toLocaleString(), icon:"fas fa-passport",
      def:"عدد الزوار القادمين من خارج البلاد لأغراض سياحية.",
      formula:"إحصاء مباشر من المنافذ الحدودية والاستبيانات.",
      analysis:"رقم منخفض جداً ويعكس ضعف التسويق الدولي وقيود السفر." },
    { id:"nights", title:"الليالي السياحية", value:metrics.nights.toLocaleString(), icon:"fas fa-moon",
      def:"إجمالي عدد ليالي المبيت التي يقضيها السياح.",
      formula:"عدد السياح × مدة الإقامة",
      analysis:"مؤشر مهم لقياس النشاط الفندقي، لكنه منخفض بسبب قلة السياح." },
    { id:"density", title:"الكثافة السياحية", value:metrics.density.toFixed(2), icon:"fas fa-chart-simple",
      def:"عدد السياح مقارنة بعدد السكان (لكل 1000 نسمة).",
      formula:"(عدد السياح / عدد السكان) × 1000",
      analysis:"منخفضة جداً، مساحة كبيرة للنمو دون ضغط على الموارد." },
    { id:"bedProd", title:"إنتاجية السرير", value:metrics.bedProductivity.toFixed(3), icon:"fas fa-procedures",
      def:"عدد السياح لكل سرير فندقي (مؤشر كفاءة التشغيل).",
      formula:"عدد السياح / عدد الأسرة",
      analysis:"منخفض جداً، يعكس ضعف استغلال الفنادق." }
  ];
  const container = document.getElementById('decisionGrid');
  container.innerHTML = '';
  indicators.forEach(ind => {
    const card = document.createElement('div');
    card.className = 'decision-card-expanded';
    card.innerHTML = `
      <div class="decision-header" data-id="${ind.id}">
        <h3><i class="${ind.icon}"></i> ${ind.title}</h3>
        <div class="decision-value-large">${ind.value}</div>
        <i class="fas fa-chevron-down"></i>
      </div>
      <div class="decision-body" id="body-${ind.id}">
        <p><strong>📖 التعريف:</strong> ${ind.def}</p>
        <p><strong>🧮 المعادلة (منهجية UNWTO):</strong> ${ind.formula}</p>
        <div class="insight"><strong>📊 التحليل:</strong> ${ind.analysis}</div>
      </div>
    `;
    container.appendChild(card);
  });
  document.querySelectorAll('.decision-header').forEach(header => {
    header.addEventListener('click', () => {
      const body = header.nextElementSibling;
      body.classList.toggle('open');
      const icon = header.querySelector('.fa-chevron-down');
      icon.style.transform = body.classList.contains('open') ? 'rotate(180deg)' : 'rotate(0deg)';
    });
  });
  updateDecisionChart(metrics.totalRevenue/1e6, UNWTO_DATA.tourists, metrics.nights, metrics.intlRevenue/1e6, metrics.occupancy, metrics.gdpShare);
}

let decisionChart = null;
function updateDecisionChart(totalRevM, tourists, nights, intlSpendM, occupancy, gdpShare) {
  const ctx = document.getElementById('decisionBarChart').getContext('2d');
  if(decisionChart) decisionChart.destroy();
  decisionChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['الإيرادات (مليون)', 'السياح الدوليون', 'الليالي السياحية', 'الإنفاق الدولي (مليون)', 'الإشغال (%)', 'مساهمة الناتج (%)'],
      datasets: [{ label: 'القيم', data: [totalRevM, tourists, nights, intlSpendM, occupancy, gdpShare], backgroundColor: '#d4af37', borderRadius: 8 }]
    },
    options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { labels: { color: '#1a2c3e' } } } }
  });
}

// ------------------------- السيناريوهات -------------------------
const scenarios = { worst: { tourists: 1500, stay: 2, dailyUSD: 80 }, base: { tourists: 2752, stay: 5, dailyUSD: 120 }, best: { tourists: 8000, stay: 7, dailyUSD: 200 } };
function setScenario(type) {
  const s = scenarios[type];
  UNWTO_DATA.tourists = s.tourists;
  UNWTO_DATA.avgStay = s.stay;
  UNWTO_DATA.dailyUSD = s.dailyUSD;
  renderDecisionCards();
  document.getElementById("dashboardTourists").innerText = s.tourists.toLocaleString();
  const metrics = computeMetrics();
  document.getElementById("dashboardTotalRev").innerText = (metrics.totalRevenue/1e9).toFixed(3) + " مليار";
  const dailyLYD = s.dailyUSD * 8.5;
  const intlRev = s.tourists * (dailyLYD * s.stay);
  const total = intlRev + UNWTO_DATA.domesticRevenue;
  document.getElementById("simTourists").innerText = s.tourists.toLocaleString();
  document.getElementById("simStay").innerText = s.stay + " أيام";
  document.getElementById("simDaily").innerText = (dailyLYD).toFixed(0) + " د.ل";
  document.getElementById("simIntlRev").innerText = (intlRev/1e6).toFixed(2) + "M د.ل";
  document.getElementById("simNights").innerText = (s.tourists * s.stay).toLocaleString();
  document.getElementById("simOccupancy").innerText = ((s.tourists * s.stay) / (75606 * 365) * 100).toFixed(2) + "%";
  document.getElementById("simTotal").innerText = (total/1e9).toFixed(3) + "B د.ل";
  document.getElementById("simGdp").innerText = (total / 200000000000 * 100).toFixed(2) + "%";
  document.getElementById("economyIntlRev").innerText = (intlRev/1e6).toFixed(2) + "M د.ل";
  document.getElementById("economyTotal").innerText = (total/1e9).toFixed(3) + "B د.ل";
  document.getElementById("economyGdpShare").innerText = (total / 200000000000 * 100).toFixed(2) + "%";
}

// ------------------------- جميع الرسوم البيانية -------------------------
function initAllCharts() {
  // 1. مخططات التحليلات البيانية
  new Chart(document.getElementById('facilityPieChart'), { type: 'pie', data: { labels: ['فنادق (384)', 'شقق فندقية (258)', 'قرى سياحية (135)'], datasets: [{ data: [384,258,135], backgroundColor: ['#1e5a88','#d4af37','#2c7a4d'] }] } });
  new Chart(document.getElementById('facilityRegionChart'), { type: 'bar', data: { labels: ['طرابلس', 'بنغازي', 'مصراتة', 'الغربية', 'الجنوبية', 'الشرقية'], datasets: [{ label: 'مرافق الإيواء', data: [322,187,99,73,50,46], backgroundColor: '#1e5a88', borderRadius: 8 }] } });
